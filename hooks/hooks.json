{
  "description": "Anchored hooks — SessionStart + UserPromptSubmit inject the persistent-memory routing block (with pre-search hits when prompts mention memory); PostToolUse / PreCompact capture session events; PreToolUse blocks dangerous code inside anchored sandbox tools.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook sessionstart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook userpromptsubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__anchored__anchored_execute|mcp__anchored__anchored_execute_file|mcp__anchored__anchored_batch_execute",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook pretooluse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|Grep|Glob|TodoWrite|Skill|Agent|mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook posttooluse"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook precompact"
          }
        ]
      }
    ]
  }
}
